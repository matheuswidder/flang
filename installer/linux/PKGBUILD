# =============================================================================
# PKGBUILD - Arch Linux / AUR Package for Flang
# Pacote PKGBUILD para Arch Linux / AUR do Flang
#
# Para instalar / To install:
#   makepkg -si
#
# Para publicar no AUR / To publish to AUR:
#   git clone ssh://aur@aur.archlinux.org/flang.git
#   cp PKGBUILD flang/
#   cd flang && makepkg --printsrcinfo > .SRCINFO
#   git add -A && git commit -m "Initial commit" && git push
#
# Mantenedor / Maintainer: Flavio <github.com/flavio>
# =============================================================================

# Informacoes do pacote / Package information
pkgname=flang
pkgver=0.2.0
pkgrel=1
pkgdesc="Linguagem de programacao declarativa full-stack (Portugues/English)"
arch=('x86_64' 'aarch64')
url="https://github.com/flaviokalleu/flang"
license=('MIT')

# Dependencias em tempo de execucao / Runtime dependencies
depends=()

# Dependencias de compilacao / Build dependencies
makedepends=('go>=1.21')

# Dependencias opcionais / Optional dependencies
optdepends=(
    'sqlite: suporte a banco SQLite'
    'postgresql: suporte a banco PostgreSQL'
    'mariadb: suporte a banco MySQL/MariaDB'
)

# Opcoes do pacote / Package options
options=('!strip' '!emptydirs')

# Fonte do codigo / Source
# Opcao 1: Baixa do GitHub Releases (binario pre-compilado)
# Option 1: Download from GitHub Releases (pre-compiled binary)
source_x86_64=("${pkgname}-v${pkgver}-linux-amd64.tar.gz::https://github.com/flaviokalleu/flang/releases/download/v${pkgver}/flang-v${pkgver}-linux-amd64.tar.gz")
source_aarch64=("${pkgname}-v${pkgver}-linux-arm64.tar.gz::https://github.com/flaviokalleu/flang/releases/download/v${pkgver}/flang-v${pkgver}-linux-arm64.tar.gz")

# Opcao 2: Compila do codigo fonte / Option 2: Build from source
# source=("${pkgname}-${pkgver}.tar.gz::https://github.com/flaviokalleu/flang/archive/refs/tags/v${pkgver}.tar.gz")

# Checksums SHA256 - atualize apos cada release / Update after each release
# Para gerar: sha256sum arquivo.tar.gz / To generate: sha256sum file.tar.gz
sha256sums_x86_64=('SKIP')
sha256sums_aarch64=('SKIP')
# sha256sums=('SKIP')  # Para build do fonte / For source build

# ---------------------------------------------------------------------------
# Prepara o ambiente de build / Prepare build environment
# ---------------------------------------------------------------------------
prepare() {
    # Verifica se o ambiente Go esta configurado / Check Go environment
    export GOPATH="${srcdir}/gopath"
    export GOCACHE="${srcdir}/gocache"
    mkdir -p "$GOPATH" "$GOCACHE"
}

# ---------------------------------------------------------------------------
# Compilacao (apenas se usando codigo fonte) / Build (only if using source)
# ---------------------------------------------------------------------------
# build() {
#     cd "${pkgname}-${pkgver}"
#     export CGO_ENABLED=1
#     export GOPATH="${srcdir}/gopath"
#     export GOCACHE="${srcdir}/gocache"
#
#     go build \
#         -trimpath \
#         -buildmode=pie \
#         -mod=readonly \
#         -modcacherw \
#         -ldflags "-linkmode external -extldflags \"${LDFLAGS}\" \
#                   -s -w \
#                   -X main.Version=${pkgver} \
#                   -X main.BuildDate=$(date -u +%Y-%m-%d)" \
#         -o "flang" .
# }

# ---------------------------------------------------------------------------
# Cria o pacote / Create package
# ---------------------------------------------------------------------------
package() {
    # Detecta arquitetura para selecionar o diretorio correto
    # Detects architecture to select correct directory
    local src_dir
    case "$CARCH" in
        x86_64)  src_dir="${srcdir}/flang-v${pkgver}-linux-amd64" ;;
        aarch64) src_dir="${srcdir}/flang-v${pkgver}-linux-arm64" ;;
        *)
            # Fallback: usa o codigo fonte compilado / Fallback: use compiled source
            src_dir="${srcdir}/${pkgname}-${pkgver}"
            ;;
    esac

    # Instala o binario / Install binary
    install -Dm755 "${src_dir}/flang" "${pkgdir}/usr/bin/flang"

    # Instala exemplos / Install examples
    if [[ -d "${src_dir}/examples" ]]; then
        install -dm755 "${pkgdir}/usr/lib/flang/examples"
        cp -r "${src_dir}/examples/." "${pkgdir}/usr/lib/flang/examples/"
    fi

    # Instala documentacao / Install documentation
    if [[ -d "${src_dir}/docs" ]]; then
        install -dm755 "${pkgdir}/usr/share/doc/${pkgname}"
        cp -r "${src_dir}/docs/." "${pkgdir}/usr/share/doc/${pkgname}/"
    fi

    # Instala README / Install README
    [[ -f "${src_dir}/README.md" ]] && \
        install -Dm644 "${src_dir}/README.md" "${pkgdir}/usr/share/doc/${pkgname}/README.md"

    # Instala licenca / Install license
    [[ -f "${src_dir}/LICENSE" ]] && \
        install -Dm644 "${src_dir}/LICENSE" "${pkgdir}/usr/share/licenses/${pkgname}/LICENSE"

    # Instala arquivo .desktop / Install .desktop file
    local script_dir
    script_dir="$(dirname "$(realpath "${BASH_SOURCE[0]}")")"
    if [[ -f "${script_dir}/flang.desktop" ]]; then
        install -Dm644 "${script_dir}/flang.desktop" \
            "${pkgdir}/usr/share/applications/flang.desktop"
    fi

    # Cria man page minima / Create minimal man page
    local mandir="${pkgdir}/usr/share/man/man1"
    install -dm755 "$mandir"
    cat > "${mandir}/flang.1" << 'EOF'
.TH FLANG 1 "2026" "Flang v0.2.0" "Flang Manual"
.SH NAME
flang \- declarative full-stack programming language
.SH SYNOPSIS
.B flang
[\fICOMMAND\fR] [\fIFILE.fg\fR]
.SH DESCRIPTION
Flang is a bilingual declarative language (Portuguese/English) that generates
complete applications from .fg files.
.SH COMMANDS
.TP
.B run \fIfile.fg\fR
Run a Flang file
.TP
.B version
Show version
.SH EXAMPLES
.TP
flang run app.fg
.SH HOMEPAGE
https://github.com/flaviokalleu/flang
EOF
    gzip -9 "${mandir}/flang.1"

    # Registra tipos MIME / Register MIME types
    install -dm755 "${pkgdir}/usr/share/mime/packages"
    cat > "${pkgdir}/usr/share/mime/packages/flang.xml" << 'EOF'
<?xml version="1.0" encoding="UTF-8"?>
<mime-info xmlns="http://www.freedesktop.org/standards/shared-mime-info">
  <mime-type type="text/x-flang">
    <comment>Flang source code</comment>
    <comment xml:lang="pt_BR">Codigo fonte Flang</comment>
    <glob pattern="*.fg"/>
    <icon name="text-x-script"/>
  </mime-type>
</mime-info>
EOF
}
