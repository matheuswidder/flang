{
  "Sistema": {
    "prefix": "sistema",
    "body": [
      "sistema ${1:meuapp}",
      "",
      "$0"
    ],
    "description": "Declaração do sistema"
  },
  "Importar": {
    "prefix": "importar",
    "body": [
      "importar \"${1:arquivo}.fg\""
    ],
    "description": "Importar arquivo"
  },
  "Importar de": {
    "prefix": "importar de",
    "body": [
      "importar ${1:dados} de \"${2:arquivo}.fg\""
    ],
    "description": "Importar seção específica"
  },
  "Tema": {
    "prefix": "tema",
    "body": [
      "tema",
      "  cor primaria \"${1:#6366f1}\"",
      "  cor secundaria \"${2:#8b5cf6}\"",
      "  cor destaque \"${3:#f59e0b}\"",
      ""
    ],
    "description": "Bloco de tema visual"
  },
  "Dados - Modelo": {
    "prefix": "modelo",
    "body": [
      "  ${1:nome}",
      "    ${2:campo}: ${3|texto,numero,dinheiro,email,telefone,status,senha,data,booleano,imagem,texto_longo|}${4| ,obrigatorio,obrigatorio unico|}",
      "    $0"
    ],
    "description": "Novo modelo dentro de dados"
  },
  "Dados": {
    "prefix": "dados",
    "body": [
      "dados",
      "",
      "  ${1:nome}",
      "    ${2:campo}: ${3|texto,numero,dinheiro,email,telefone,status,senha,data,booleano,imagem|}",
      "    $0",
      ""
    ],
    "description": "Bloco de dados com modelo"
  },
  "Tela": {
    "prefix": "tela",
    "body": [
      "  tela ${1:nome}",
      "    titulo \"${2:Titulo}\"",
      "    lista ${3:modelo}",
      "      mostrar ${4:campo}",
      "    botao ${5|azul,verde,vermelho|}",
      "      texto \"${6:Novo}\"",
      ""
    ],
    "description": "Nova tela"
  },
  "Telas": {
    "prefix": "telas",
    "body": [
      "telas",
      "",
      "  tela ${1:nome}",
      "    titulo \"${2:Titulo}\"",
      "    lista ${3:modelo}",
      "      mostrar ${4:campo}",
      "    botao azul",
      "      texto \"${5:Novo}\"",
      ""
    ],
    "description": "Bloco de telas"
  },
  "Evento": {
    "prefix": "quando",
    "body": [
      "  quando clicar \"${1:Botao}\"",
      "    ${2|criar,atualizar,deletar|} ${3:modelo}",
      ""
    ],
    "description": "Novo evento"
  },
  "Eventos": {
    "prefix": "eventos",
    "body": [
      "eventos",
      "",
      "  quando clicar \"${1:Botao}\"",
      "    ${2|criar,atualizar,deletar|} ${3:modelo}",
      ""
    ],
    "description": "Bloco de eventos"
  },
  "Autenticação": {
    "prefix": "autenticacao",
    "body": [
      "autenticacao",
      "  modelo: ${1:usuario}",
      "  campo_login: ${2:email}",
      "  campo_senha: ${3:senha}",
      "  roles: ${4:admin, usuario}",
      ""
    ],
    "description": "Configuração de autenticação"
  },
  "Logica": {
    "prefix": "logica",
    "body": [
      "logica",
      "",
      "  $0",
      ""
    ],
    "description": "Bloco de lógica"
  },
  "Função": {
    "prefix": "funcao",
    "body": [
      "  funcao ${1:nome}(${2:params})",
      "    ${3:retornar $0}",
      ""
    ],
    "description": "Definir função"
  },
  "Se / Senão": {
    "prefix": "se",
    "body": [
      "  se ${1:condicao}",
      "    ${2:acao}",
      "  senao",
      "    ${3:acao_alternativa}",
      ""
    ],
    "description": "Condicional se/senão"
  },
  "Definir variável": {
    "prefix": "definir",
    "body": [
      "  definir ${1:nome} = ${2:valor}"
    ],
    "description": "Definir variável"
  },
  "Repetir": {
    "prefix": "repetir",
    "body": [
      "  repetir ${1:10} vezes",
      "    ${0}",
      ""
    ],
    "description": "Loop repetir N vezes"
  },
  "Enquanto": {
    "prefix": "enquanto",
    "body": [
      "  enquanto ${1:condicao}",
      "    ${0}",
      ""
    ],
    "description": "Loop enquanto"
  },
  "Para cada": {
    "prefix": "para cada",
    "body": [
      "  para cada ${1:item} em ${2:lista}",
      "    ${0}",
      ""
    ],
    "description": "Loop para cada"
  },
  "Cron": {
    "prefix": "cron",
    "body": [
      "  cron cada ${1|1,5,10,30|} ${2|minuto,hora|}",
      "    ${0}",
      ""
    ],
    "description": "Tarefa agendada"
  },
  "Integração WhatsApp": {
    "prefix": "whatsapp",
    "body": [
      "integracoes",
      "",
      "  whatsapp",
      "    mensagem \"${1:Texto da mensagem}\"",
      ""
    ],
    "description": "Integração com WhatsApp"
  },
  "Banco": {
    "prefix": "banco",
    "body": [
      "banco",
      "  tipo: ${1|sqlite,mysql,postgresql|}",
      "  nome: ${2:meuapp}",
      ""
    ],
    "description": "Configuração do banco de dados"
  },
  "Projeto plano completo": {
    "prefix": "flang-plano",
    "body": [
      "sistema ${1:meuapp}",
      "",
      "tema",
      "  cor primaria \"${2:#6366f1}\"",
      "  cor secundaria \"${3:#8b5cf6}\"",
      "",
      "dados",
      "",
      "  ${4:item}",
      "    nome: texto obrigatorio",
      "    ${5:descricao}: ${6:texto}",
      "    status: status",
      "",
      "telas",
      "",
      "  tela ${4:item}s",
      "    titulo \"${7:Itens}\"",
      "    lista ${4:item}",
      "      mostrar nome",
      "      mostrar ${5:descricao}",
      "      mostrar status",
      "    botao azul",
      "      texto \"Novo\"",
      "",
      "eventos",
      "",
      "  quando clicar \"Novo\"",
      "    criar ${4:item}",
      ""
    ],
    "description": "Projeto completo em modo plano (um arquivo)"
  },
  "Projeto organizado - inicio": {
    "prefix": "flang-inicio",
    "body": [
      "sistema ${1:meuapp}",
      "",
      "importar \"tema.fg\"",
      "importar \"dados/${2:modelo}.fg\"",
      "importar \"telas/${2:modelo}s.fg\"",
      "importar \"eventos/acoes.fg\"",
      ""
    ],
    "description": "Entry point para projeto organizado"
  }
}
