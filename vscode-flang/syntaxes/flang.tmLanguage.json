{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "Flang",
  "scopeName": "source.flang",
  "patterns": [
    { "include": "#comments" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#constants" },
    { "include": "#operators" },
    { "include": "#import-statement" },
    { "include": "#block-keywords" },
    { "include": "#screen-keywords" },
    { "include": "#type-keywords" },
    { "include": "#modifier-keywords" },
    { "include": "#event-keywords" },
    { "include": "#logic-keywords" },
    { "include": "#auth-keywords" },
    { "include": "#integration-keywords" },
    { "include": "#relationship-keywords" },
    { "include": "#theme-keywords" },
    { "include": "#scripting-keywords" },
    { "include": "#entity-names" },
    { "include": "#function-call" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.hash.flang",
          "match": "#.*$"
        },
        {
          "name": "comment.line.double-slash.flang",
          "match": "//.*$"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.flang",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.flang",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.flang",
          "match": "\\b[0-9]+(\\.[0-9]+)?\\b"
        }
      ]
    },
    "constants": {
      "patterns": [
        {
          "name": "constant.language.flang",
          "match": "\\b(verdadeiro|falso|nulo|nada|true|false|null|nothing)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.comparison.flang",
          "match": "(==|!=|>=|<=|>|<)"
        },
        {
          "name": "keyword.operator.arithmetic.flang",
          "match": "(\\+|\\-|\\*|/|%)"
        },
        {
          "name": "keyword.operator.assignment.flang",
          "match": "="
        }
      ]
    },
    "import-statement": {
      "patterns": [
        {
          "name": "keyword.control.import.flang",
          "match": "\\b(importar|import)\\b"
        },
        {
          "name": "keyword.control.from.flang",
          "match": "\\b(de|from)\\b"
        }
      ]
    },
    "block-keywords": {
      "patterns": [
        {
          "name": "keyword.control.block.flang",
          "match": "^\\s*(sistema|dados|telas|acoes|eventos|integracoes|tema|logica|banco|autenticacao|config|system|models|screens|actions|events|integrations|theme|logic|database|db|auth|authentication)\\b"
        }
      ]
    },
    "screen-keywords": {
      "patterns": [
        {
          "name": "keyword.control.screen.flang",
          "match": "\\b(tela|titulo|lista|mostrar|botao|formulario|entrada|busca|dashboard|grafico|tabela|campo|selecionar|area_texto|screen|title|list|show|button|form|input|search|chart|table|field|select|textarea)\\b"
        }
      ]
    },
    "type-keywords": {
      "patterns": [
        {
          "name": "storage.type.flang",
          "match": "\\b(texto|texto_longo|numero|dinheiro|email|telefone|status|senha|data|booleano|imagem|arquivo|upload|link|enum|text|long_text|number|money|currency|phone|password|date|boolean|image|file)\\b"
        }
      ]
    },
    "modifier-keywords": {
      "patterns": [
        {
          "name": "storage.modifier.flang",
          "match": "\\b(obrigatorio|unico|padrao|indice|soft_delete|required|unique|default|index)\\b"
        }
      ]
    },
    "event-keywords": {
      "patterns": [
        {
          "name": "keyword.control.event.flang",
          "match": "\\b(quando|clicar|criar|atualizar|deletar|salvar|enviar|when|click|create|update|delete|save|send)\\b"
        }
      ]
    },
    "logic-keywords": {
      "patterns": [
        {
          "name": "keyword.control.logic.flang",
          "match": "\\b(se|senao|igual|maior|menor|maior_igual|menor_igual|diferente|e|ou|nao|entao|validar|calcular|definir|retornar|mudar|para|para_cada|funcao|tentar|erro|if|else|equals|equal|greater|less|and|or|not|then|validate|compute|set|return|change|to|for_each|function|try|error)\\b"
        }
      ]
    },
    "auth-keywords": {
      "patterns": [
        {
          "name": "keyword.other.auth.flang",
          "match": "\\b(login|registro|usuario|permissao|requer|admin|publico|register|user|permission|requires|public|modelo|campo_login|campo_senha|roles)\\b"
        }
      ]
    },
    "integration-keywords": {
      "patterns": [
        {
          "name": "keyword.other.integration.flang",
          "match": "\\b(whatsapp|mensagem|notificar|cron|cada|hora|minuto|chamar|api|webhook|pagamento|message|notify|every|hour|minute|call|payment)\\b"
        }
      ]
    },
    "relationship-keywords": {
      "patterns": [
        {
          "name": "keyword.other.relationship.flang",
          "match": "\\b(pertence_a|tem_muitos|muitos_para_muitos|belongs_to|has_many|many_to_many)\\b"
        }
      ]
    },
    "theme-keywords": {
      "patterns": [
        {
          "name": "support.type.theme.flang",
          "match": "\\b(cor|icone|escuro|primaria|secundaria|destaque|color|icon|dark)\\b"
        }
      ]
    },
    "scripting-keywords": {
      "patterns": [
        {
          "name": "keyword.control.scripting.flang",
          "match": "\\b(pausar|continuar|parar|enquanto|repetir|vezes|em|ate|pause|continue|break|stop|while|repeat|times|in|until|for|each|print)\\b"
        }
      ]
    },
    "entity-names": {
      "patterns": [
        {
          "name": "entity.name.type.flang",
          "match": "(?<=^\\s*(sistema|system)\\s+)\\w+",
          "comment": "System name after sistema/system"
        },
        {
          "name": "entity.name.section.flang",
          "match": "(?<=^\\s*(tela|screen)\\s+)\\w+",
          "comment": "Screen name after tela/screen"
        }
      ]
    },
    "function-call": {
      "patterns": [
        {
          "name": "entity.name.function.flang",
          "match": "(?<=^\\s*(funcao|function)\\s+)\\w+",
          "comment": "Function name after funcao/function"
        }
      ]
    }
  }
}
