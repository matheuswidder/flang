{
  "name": "flang",
  "displayName": "Flang Language",
  "description": "Syntax highlighting, snippets and language support for Flang (.fg files)",
  "version": "0.4.0",
  "publisher": "flang",
  "engines": {
    "vscode": "^1.75.0"
  },
  "categories": [
    "Programming Languages",
    "Snippets"
  ],
  "keywords": [
    "flang",
    "fg",
    "declarative",
    "fullstack",
    "bilingual"
  ],
  "icon": "icon.png",
  "contributes": {
    "languages": [
      {
        "id": "flang",
        "aliases": [
          "Flang",
          "flang"
        ],
        "extensions": [
          ".fg"
        ],
        "configuration": "./language-configuration.json",
        "icon": {
          "light": "./icon.png",
          "dark": "./icon.png"
        }
      }
    ],
    "grammars": [
      {
        "language": "flang",
        "scopeName": "source.flang",
        "path": "./syntaxes/flang.tmLanguage.json"
      }
    ],
    "snippets": [
      {
        "language": "flang",
        "path": "./snippets/flang.json"
      }
    ]
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/flavio/flang"
  },
  "license": "MIT"
}
