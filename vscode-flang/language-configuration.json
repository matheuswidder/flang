{
  "comments": {
    "lineComment": "#"
  },
  "brackets": [
    ["(", ")"]
  ],
  "autoClosingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"", "notIn": ["string"] }
  ],
  "surroundingPairs": [
    { "open": "(", "close": ")" },
    { "open": "\"", "close": "\"" }
  ],
  "indentationRules": {
    "increaseIndentPattern": "^\\s*(sistema|dados|telas|tela|acoes|eventos|tema|logica|banco|integracoes|autenticacao|config|system|models|screens|screen|actions|events|theme|logic|database|integrations|authentication|quando|when|se|if|senao|else|funcao|function|enquanto|while|repetir|repeat|para cada|for_each|lista|list|botao|button|formulario|form|whatsapp|cron|tentar|try)\\b",
    "decreaseIndentPattern": "^\\s*(senao|else|erro|error)\\b"
  },
  "wordPattern": "(-?\\d*\\.\\d\\w*)|([^\\`\\~\\!\\@\\#\\%\\^\\&\\*\\(\\)\\=\\+\\[\\{\\]\\}\\\\\\|\\;\\:\\'\\\"\\,\\.\\<\\>\\/\\?\\s]+)",
  "onEnterRules": [
    {
      "beforeText": "^\\s*(sistema|dados|telas|tela|acoes|eventos|tema|logica|banco|integracoes|autenticacao|quando|se|senao|funcao|enquanto|repetir|lista|botao|formulario|whatsapp|cron|tentar)\\b.*$",
      "action": {
        "indent": "indent"
      }
    }
  ]
}
