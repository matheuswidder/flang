dados

  ticket
    protocolo: texto unico
    contato: texto pertence_a contato
    atendente: texto pertence_a usuario
    fila: texto pertence_a fila
    categoria: texto
    prioridade: enum(baixa, media, alta, urgente)
    canal: enum(whatsapp, telegram, instagram, facebook, widget)
    empresa: texto pertence_a empresa
    motivo_fechamento: texto
    avaliacao: numero
    reaberturas: numero
    transferencias: numero
    status: enum(pendente, aberto, aguardando, resolvido, fechado)
